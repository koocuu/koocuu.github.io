---
import SiteNav from '@components/SiteNav.astro';
import BaseLayout from '@layouts/BaseLayout.astro';
import { profile, socialLinks } from '@data/profile';
import { copy, languages, normalizeLang } from '@data/i18n';

export function getStaticPaths() {
  return languages.map((lang) => ({ params: { lang } }));
}

const lang = normalizeLang(Astro.params.lang);
const t = copy[lang];

const icons: Record<string, string> = {
  GitHub: '<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2C6.48 2 2 6.58 2 12.26c0 4.5 2.87 8.32 6.84 9.67.5.1.68-.22.68-.48 0-.24-.01-.87-.01-1.7-2.78.62-3.37-1.37-3.37-1.37-.45-1.18-1.11-1.5-1.11-1.5-.91-.64.07-.62.07-.62 1 .07 1.53 1.06 1.53 1.06.9 1.57 2.34 1.12 2.91.86.09-.66.35-1.12.63-1.38-2.22-.26-4.55-1.14-4.55-5.06 0-1.12.39-2.03 1.03-2.75-.1-.26-.45-1.3.1-2.7 0 0 .84-.28 2.75 1.05a9.36 9.36 0 0 1 5 0c1.91-1.33 2.75-1.05 2.75-1.05.55 1.4.2 2.44.1 2.7.64.72 1.03 1.63 1.03 2.75 0 3.93-2.34 4.79-4.57 5.05.36.32.68.94.68 1.9 0 1.37-.01 2.48-.01 2.82 0 .27.18.59.69.48A10.02 10.02 0 0 0 22 12.26C22 6.58 17.52 2 12 2Z"/></svg>',
  Instagram: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4.2"/><circle cx="17.2" cy="6.8" r="1.1" fill="currentColor" stroke="none"/></svg>',
  Email: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="5" width="18" height="14" rx="2.5"/><path d="m3.5 7 8.5 6 8.5-6"/></svg>',
};

const wechatIcon = '<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M9 3C4.6 3 1 6 1 9.7c0 2.1 1.1 3.9 2.9 5.1L3 17.5l3-1.6c.9.25 1.9.38 2.9.38.3 0 .6 0 .9-.03a5.7 5.7 0 0 1-.3-1.8c0-3.3 3-6 6.8-6 .3 0 .6.02.9.05C16.7 5.4 13.2 3 9 3Zm-2.5 4.2a1 1 0 1 1 0 2 1 1 0 0 1 0-2Zm5 0a1 1 0 1 1 0 2 1 1 0 0 1 0-2Zm4.8 3.1c-3.3 0-6 2.3-6 5.1 0 2.9 2.7 5.1 6 5.1.8 0 1.5-.1 2.2-.3l2.3 1.3-.3-2.2c1.3-.9 2.1-2.3 2.1-3.9 0-2.8-2.7-5.1-6-5.1Zm-2 2.9a.8.8 0 1 1 0 1.6.8.8 0 0 1 0-1.6Zm4 0a.8.8 0 1 1 0 1.6.8.8 0 0 1 0-1.6Z"/></svg>';
---

<BaseLayout lang={lang} title={t.contact.title} description={t.contact.description}>
  <SiteNav lang={lang} />
  <main>
    <section class="page-title section-shell">
      <p class="eyebrow">{t.contact.eyebrow}</p>
      <h1>{t.contact.heading}</h1>
      <p class="page-lede">{t.contact.lede}</p>
    </section>

    <section class="section-shell contact-page">
      <div class="contact-grid">
        {socialLinks.map((item) => (
          <a class="contact-card" href={item.href} target={item.href.startsWith('http') ? '_blank' : undefined} rel="noreferrer">
            <span class="contact-icon" set:html={icons[item.label] ?? ''} />
            <span class="contact-text">
              <span>{item.label}</span>
              <strong>{item.value}</strong>
            </span>
          </a>
        ))}
        <div class="contact-card wechat">
          <span class="contact-icon" set:html={wechatIcon} />
          <span class="contact-text">
            <span>WeChat</span>
            <strong>{profile.wechat}</strong>
          </span>
          <img src="/images/wechat_qr-card.png" alt="WeChat QR code" width="560" height="764" loading="lazy" decoding="async" />
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
