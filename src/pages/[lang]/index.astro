---
import SiteNav from '@components/SiteNav.astro';
import BaseLayout from '@layouts/BaseLayout.astro';
import { copy, languages, normalizeLang } from '@data/i18n';

export function getStaticPaths() {
  return languages.map((lang) => ({ params: { lang } }));
}

const lang = normalizeLang(Astro.params.lang);
const t = copy[lang];
---

<BaseLayout lang={lang} title="Cu" description={lang === 'zh' ? 'Cu 的个人网站和博客。' : 'Cu personal website and blog.'}>
  <SiteNav lang={lang} />
  <main>
    <section class="hero section-shell">
      <div class="hero-copy">
        <p class="eyebrow">{t.home.eyebrow}</p>
        <h1 class="hero-headline">{t.home.headline}</h1>
        <p class="hero-note">{t.home.note}</p>
        <div class="hero-cta">
          <a class="button primary" href={`/${lang}/blog/`} data-astro-prefetch="hover">{t.home.readBlog}</a>
          <a class="button ghost" href={`/${lang}/about/`} data-astro-prefetch="hover">{t.home.viewProfile}</a>
        </div>
      </div>
      <div class="hero-portrait">
        <picture>
          <source srcset="/images/cu-540.avif" media="(max-width: 640px)" type="image/avif" />
          <source srcset="/images/cu-900.avif" type="image/avif" />
          <source srcset="/images/cu-540.webp" media="(max-width: 640px)" type="image/webp" />
          <source srcset="/images/cu-900.webp" type="image/webp" />
          <source srcset="/images/cu-540.jpg" media="(max-width: 640px)" type="image/jpeg" />
          <img src="/images/cu-900.jpg" alt="Cu portrait" width="900" height="1200" decoding="async" fetchpriority="high" />
        </picture>
      </div>
    </section>

    <section class="section-shell">
      <div class="section-header">
        <div>
          <p class="eyebrow">{t.home.projectsEyebrow}</p>
          <h2>{t.home.projectsTitle}</h2>
        </div>
      </div>
      <p class="section-intro">{t.home.projectsIntro}</p>
      <div class="project-grid">
        {t.projects.map((project) => (
          <article class="project-card">
            <div class="project-card-header">
              <div>
                <p class="project-status">{project.status}</p>
                <h3>{project.title}</h3>
              </div>
              <a class="text-link" href={project.href} target="_blank" rel="noreferrer">
                {lang === 'zh' ? '访问' : 'Visit'}
              </a>
            </div>
            <p>{project.description}</p>
            <p class="project-note">{project.note}</p>
            <p class="project-access">{project.access}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section-shell">
      <div class="section-header">
        <div>
          <p class="eyebrow">{t.home.servicesEyebrow}</p>
          <h2>{t.home.servicesTitle}</h2>
        </div>
        <a class="text-link" href={`/${lang}/contact/`} data-astro-prefetch="hover">{t.home.contact}</a>
      </div>
      <p class="section-intro">{t.home.servicesIntro}</p>
      <div class="principle-grid">
      {t.services.map((item) => (
        <article class="principle-card">
          <h3>{item.title}</h3>
          <p>{item.description}</p>
        </article>
      ))}
      </div>
    </section>

    <section class="section-shell writing-section">
      <div class="section-header">
        <div>
          <p class="eyebrow">{t.home.writingEyebrow}</p>
          <h2>{t.home.writingTitle}</h2>
        </div>
      </div>
      <p class="section-intro">{t.home.writingIntro}</p>
      <div class="writing-list">
        {t.writingChannels.map((channel) => {
          const href = channel.href ? `/${lang}${channel.href}` : undefined;
          const qr = (channel as { qr?: string }).qr;
          const content = (
            <>
              <div class="writing-item-body">
                <p class="channel-label">{channel.label}</p>
                <h3>{channel.title}</h3>
                <p class="writing-item-desc">{channel.description}</p>
              </div>
              <span class:list={['channel-action', { 'has-qr': qr }]}>
                {channel.action}
                {qr && <img class="channel-qr" src={qr} alt={`${channel.title} QR code`} loading="lazy" />}
              </span>
            </>
          );

          return href ? (
            <a class="writing-item" href={href} data-astro-prefetch="hover">
              {content}
            </a>
          ) : (
            <article class="writing-item">
              {content}
            </article>
          );
        })}
      </div>
    </section>
  </main>
</BaseLayout>
