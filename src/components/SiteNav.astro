---
import { alternateLang, copy, normalizeLang, type Lang } from '@data/i18n';

interface Props {
  lang?: Lang;
}

const lang = normalizeLang(Astro.props.lang);
const t = copy[lang];
const otherLang = alternateLang(lang);
const currentPath = Astro.url.pathname.replace(/^\/(en|zh)/, '') || '/';
const otherHref = `/${otherLang}${currentPath}`;
const navItems = [
  { href: `/${lang}/about/`, label: t.nav.about },
  { href: `/${lang}/blog/`, label: t.nav.blog },
  { href: `/${lang}/contact/`, label: t.nav.contact },
];

const isActive = (href: string) => {
  const itemPath = href.replace(/^\/(en|zh)/, '');
  return currentPath === itemPath || currentPath.startsWith(itemPath);
};
const isHome = currentPath === '/';
---

<header class="site-header">
  <a class:list={['brand', { active: isHome }]} href={`/${lang}/`} aria-label="Cu home" data-astro-prefetch="viewport">Cu</a>
  <div class="nav-cluster">
    <nav class="site-nav" aria-label="Primary navigation">
      {navItems.map((item) => (
        <a class:list={{ active: isActive(item.href) }} aria-current={isActive(item.href) ? 'page' : undefined} href={item.href} data-astro-prefetch="viewport">
          {item.label}
        </a>
      ))}
    </nav>
    <a class="lang-switch" href={otherHref} data-astro-prefetch="hover">{t.nav.switch}</a>
  </div>
</header>
