---
import '@styles/global.css';
import '@fontsource-variable/fraunces';
import '@fontsource-variable/inter';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title?: string;
  description?: string;
  lang?: 'en' | 'zh';
}

const {
  title,
  description = 'Cu personal website and blog.',
  lang = 'en',
} = Astro.props;
const pageTitle = !title || title === 'Cu' ? 'Cu · AI, Codes & Notes' : `${title} · Cu`;
const ogImage = new URL('/images/cu-900.jpg', Astro.site).href;
const counterLabels = lang === 'zh'
  ? { views: '访问', visitors: '访客', viewUnit: '次', visitorUnit: '人' }
  : { views: 'Views', visitors: 'Visitors', viewUnit: '', visitorUnit: '' };
---

<!doctype html>
<html lang={lang === 'zh' ? 'zh-CN' : 'en'}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#f7f7f4" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <title>{pageTitle}</title>
    <link rel="icon" href="/favicon.ico?v=4" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/images/favicon-32.png?v=4" />
    <link rel="icon" type="image/png" sizes="512x512" href="/images/cu-icon-512.png?v=4" />
    <link rel="apple-touch-icon" href="/images/apple-touch-icon.png?v=4" />
    <ClientRouter />
  </head>
  <body>
    <slot />
    <footer class="site-footer" aria-label={lang === 'zh' ? '网站统计' : 'Site statistics'}>
      <div class="footer-stats">
        <span id="busuanzi_container_site_pv">
          {counterLabels.views}
          <strong id="busuanzi_value_site_pv">-</strong>{counterLabels.viewUnit}
        </span>
        <span class="footer-dot" aria-hidden="true">/</span>
        <span id="busuanzi_container_site_uv">
          {counterLabels.visitors}
          <strong id="busuanzi_value_site_uv">-</strong>{counterLabels.visitorUnit}
        </span>
      </div>
      <p class="footer-copyright">© 2026 koocuu.com. All rights reserved.</p>
    </footer>
    <script is:inline>
      (() => {
        const busuanziSrc = 'https://busuanzi.ibruce.info/busuanzi/2.3/busuanzi.pure.mini.js';
        const counterIds = ['busuanzi_value_site_pv', 'busuanzi_value_site_uv'];

        const readCounterValues = () => {
          const values = {};
          counterIds.forEach((id) => {
            const text = document.getElementById(id)?.textContent?.trim();
            if (text && text !== '-') {
              values[id] = text;
            }
          });
          return values;
        };

        const cacheCounterValues = () => {
          const values = readCounterValues();
          if (Object.keys(values).length) {
            window.__cuBusuanziCounts = {
              ...(window.__cuBusuanziCounts || {}),
              ...values,
            };
          }
        };

        const applyCachedValues = () => {
          const values = window.__cuBusuanziCounts;
          if (!values) return;
          Object.entries(values).forEach(([id, value]) => {
            const el = document.getElementById(id);
            if (el) {
              el.textContent = value;
            }
          });
        };

        const observeCounterValues = () => {
          window.__cuBusuanziObserver?.disconnect();
          const observer = new MutationObserver(cacheCounterValues);
          counterIds.forEach((id) => {
            const el = document.getElementById(id);
            if (el) {
              observer.observe(el, { childList: true, characterData: true, subtree: true });
            }
          });
          window.__cuBusuanziObserver = observer;
        };

        const refreshCounterDisplay = () => {
          applyCachedValues();
          observeCounterValues();
        };

        const loadCounterOnce = () => {
          if (document.querySelector('script[data-cu-busuanzi]')) return;
          const script = document.createElement('script');
          script.async = true;
          script.src = busuanziSrc;
          script.dataset.cuBusuanzi = 'true';
          document.body.appendChild(script);
        };

        if (!window.__cuBusuanziReady) {
          window.__cuBusuanziReady = true;
          document.addEventListener('astro:page-load', refreshCounterDisplay);
        }

        refreshCounterDisplay();

        if (!window.__cuBusuanziCounted) {
          window.__cuBusuanziCounted = true;
          loadCounterOnce();
        }
      })();
    </script>
  </body>
</html>
